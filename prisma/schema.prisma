// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  role       String    @default("client") // "superadmin", "client"
  plan       String    @default("Starter") // "Starter", "Premium", "Business"
  createdAt  DateTime  @default(now()) @map("created_at")
  events     Event[]
  payments   Payment[]

  @@map("users")
}

model Event {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  slug        String         @unique
  type        String         // "Boda", "XV años", etc.
  date        DateTime
  time        String
  city        String
  status      String         @default("draft") // "draft", "published"
  templateId  String?        @map("template_id")
  template    Template?      @relation(fields: [templateId], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")
  sections    EventSection[]
  guests      Guest[]
  rsvps       Rsvp[]
  gallery     GalleryItem[]
  gifts       GiftOption[]

  @@map("events")
}

model EventSection {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type      String   // "portada", "nombres", "ubicacion", etc.
  title     String
  content   String?  @db.Text
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")

  @@map("event_sections")
}

model Guest {
  id             String        @id @default(uuid())
  eventId        String        @map("event_id")
  event          Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  maxCompanions  Int           @default(0) @map("max_companions")
  tableName      String?       @map("table_name")
  token          String        @unique
  qrCodeUrl      String?       @map("qr_code_url")
  rsvpStatus     String        @default("pendiente") @map("rsvp_status") // "pendiente", "confirmado", "cancelado"
  checkedIn      Boolean       @default(false) @map("checked_in")
  checkedInAt    DateTime?     @map("checked_in_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  rsvp           Rsvp?
  galleryItems   GalleryItem[]

  @@map("guests")
}

model Rsvp {
  id               String    @id @default(uuid())
  guestId          String    @unique @map("guest_id")
  guest            Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  eventId          String    @map("event_id")
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status           String    // "confirmado", "cancelado"
  companionsCount  Int       @default(0) @map("companions_count")
  companionsNames  String?   @map("companions_names") @db.Text
  foodRestrictions String?   @map("food_restrictions") @db.Text
  message          String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")

  @@map("rsvps")
}

model Template {
  id         String   @id @default(uuid())
  name       String
  category   String   // "Bodas", "XV Años", etc.
  previewUrl String   @map("preview_url")
  configJson String   @map("config_json") @db.Text
  isPremium  Boolean  @default(false) @map("is_premium")
  events     Event[]

  @@map("templates")
}

model GalleryItem {
  id                 String   @id @default(uuid())
  eventId            String   @map("event_id")
  event              Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploadedByGuestId  String?  @map("uploaded_by_guest_id")
  guest              Guest?   @relation(fields: [uploadedByGuestId], references: [id], onDelete: SetNull)
  imageUrl           String   @map("image_url")
  isApproved         Boolean  @default(false) @map("is_approved")
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("gallery_items")
}

model GiftOption {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type        String   // "bank", "link", "store"
  title       String
  description String?  @db.Text
  url         String?
  bankData    String?  @map("bank_data") @db.Text

  @@map("gift_options")
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  features     String   @db.Text // JSON or comma separated
  limitsJson   String   @map("limits_json") @db.Text

  @@map("plans")
}

model Payment {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId     String   @map("plan_id")
  provider   String   // "stripe", "mercadopago"
  status     String   // "pending", "completed", "failed"
  amount     Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("payments")
}
