<IfModule mod_rewrite.c>
    RewriteEngine Off
</IfModule>

# Only allow image files
<FilesMatch "\.(?i:jpg|jpeg|png|gif|webp|svg)$">
    Require all granted
</FilesMatch>

<FilesMatch "\.(?i:php|phtml|php3|php4|php5|phps)$">
    Require all denied
</FilesMatch>

# Prevent script execution
php_flag engine off
